{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/auth/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/login",
            "destination": "/api/index.js"
        },
        {
            "source": "/signup",
            "destination": "/api/index.js"
        },
        {
            "source": "/logout",
            "destination": "/api/index.js"
        }
    ]
}