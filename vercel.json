{
    "version": 2,
    "builds": [
        {
            "src": "app.js",
            "use": "@vercel/node"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/app.js"
        },
        {
            "source": "/auth/(.*)",
            "destination": "/app.js"
        },
        {
            "source": "/login",
            "destination": "/app.js"
        },
        {
            "source": "/signup",
            "destination": "/app.js"
        },
        {
            "source": "/logout",
            "destination": "/app.js"
        },
        {
            "source": "/(.*)",
            "destination": "/public/$1"
        }
    ]
}