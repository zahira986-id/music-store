{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/auth/(.*)",
            "destination": "/api"
        },
        {
            "source": "/login",
            "destination": "/api"
        },
        {
            "source": "/signup",
            "destination": "/api"
        },
        {
            "source": "/logout",
            "destination": "/api"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}